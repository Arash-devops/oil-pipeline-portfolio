# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oil_warehouse
DB_USER=arash
DB_PASSWORD=warehouse_dev_2026

# Commodities to ingest (comma-separated ticker symbols)
COMMODITIES=CL=F,BZ=F,NG=F,HO=F

# Data source label written to dim_source
SOURCE_NAME=Yahoo Finance

# Logging
LOG_LEVEL=INFO

# Retry behaviour for network calls
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=2.0

# How many years back to fetch on a full backfill
BACKFILL_YEARS=5

# Rows per staging INSERT batch
BATCH_SIZE=500
